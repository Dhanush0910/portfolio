      replacement_content: "import { GoogleGenAI } from \"@google/genai\";\nimport * as fs from \"fs\";\nimport { execSync } from \"child_process\";\n\nasync function main() {\n  console.log(\"Downloading Pinterest image...\");\n  const imageUrl = \"https://i.pinimg.com/736x/40/41/7a/40417a66cbe0ca2ab9038e29a946d688.jpg\";\n  const imagePath = \"./portfolio_design.jpg\";\n  \n  try {\n    execSync(`curl -s -o ${imagePath} \"${imageUrl}\"`);\n    console.log(\"Image downloaded successfully!\");\n  } catch (err) {\n    console.error(\"Failed to download image:\", err);\n    return;\n  }\n\n  const ai = new GoogleGenAI({\n    apiKey: process.env.GEMINI_API_KEY,\n    httpOptions: {\n      headers: {\n        \'User-Agent\': \'aistudio-build\',\n      }\n    }\n  });\n\n  console.log(\"Analyzing image with Gemini...\");\n  const imageBuffer = fs.readFileSync(imagePath);\n  const base64Data = imageBuffer.toString(\"base64\");\n\n  const response = await ai.models.generateContent({\n    model: \"gemini-3.5-flash\",\n    contents: [\n      {\n        inlineData: {\n          mimeType: \"image/jpeg\",\n          data: base64Data\n        }\n      },\n      \"Analyze this developer portfolio design. Describe its overall layout, color scheme (hex codes or Tailwind color equivalents), typography, grid design (e.g. Bento grid, sections, layouts), specific components (cards, details, metrics, charts, buttons, tech stack display), dark/light styling, and any micro-interactions/animations suggested by the static screenshot (e.g. framer motion transitions). Provide a clean markdown breakdown so I can implement it perfectly in React and Tailwind CSS.\"\n    ]\n  });\n\n  console.log(\"\\n--- DESIGN ANALYSIS FROM GEMINI ---\\n\");\n  console.log(response.text);\n  console.log(\"\\n------------------------------------\\n\");\n}\n\nmain().catch(err => {\n  console.error(\"Error running script:\", err);\n});\n"
