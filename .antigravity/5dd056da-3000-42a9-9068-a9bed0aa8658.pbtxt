    replacement_chunks {
      target_content: "const projects: Project[] = [\n  {\n    id: \"recognito-canvas\",\n    title: \"Recognito Slat Engine\",\n    subtitle: \"Creative WebGL Layout & Animation System\",\n    desc: \"An immersive landing page engine utilizing 3D matrix-rotated canvas slats, dynamic mouse-parallax, and stateful fluid glow visualizers.\",\n    longDesc: \"A complete visual masterpiece engineered to push the boundaries of browser rendering performance. By combining high-performance WebGL shaders, SVG matrix maps, and rigid GPU animation cycles, the Slat Engine serves fluid, smooth frame rates on extreme widescreen formats.\",\n    tags: [\"WebGL\", \"Three.js\", \"Framer Motion\", \"Tailwind CSS\", \"GLSL Shaders\"],\n    category: \"AI/WebGL\",\n    image: \"https://images.unsplash.com/photo-1618005182384-a83a8bd57fbe?auto=format&fit=crop&w=800&q=80\",\n    features: [\n      \"Custom vertex & fragment shader matrices\",\n      \"Dynamic column mouse coordinate mapping\",\n      \"Zero-latency background glow pulse\",\n      \"Widescreen fluid responsive viewport anchors\"\n    ],\n    metrics: [\"60 FPS Rendering Consistency\", \"30% Lower GPU Utilization\", \"100% Score on Core Web Vitals\"]\n  },\n  {\n    id: \"omnisearch-cloud\",\n    title: \"OmniSearch Core\",\n    subtitle: \"High-Throughput Vector Indexing Search Hub\",\n    desc: \"A cluster indexer compiling over 40M+ relational objects, powered by high-concurrency Node processes and ultra-low latency caching.\",\n    longDesc: \"OmniSearch core represents next-generation distributed lookup systems. Built entirely on an asynchronous non-blocking I/O loop, it distributes concurrent lookup weights over multiple replica endpoints, keeping page response metrics under 35ms even during traffic spikes.\",\n    tags: [\"Node.js\", \"Redis\", \"TypeScript\", \"PostgreSQL\", \"ElasticSearch\", \"gRPC\"],\n    category: \"Fullstack\",\n    image: \"https://images.unsplash.com/photo-1639762681485-074b7f938ba0?auto=format&fit=crop&w=800&q=80\",\n    features: [\n      \"Multi-replica parallelized indexing stream\",\n      \"Custom priority queues with high-concurrency throttling\",\n      \"Redis memory caching with automatic cluster evictions\",\n      \"Fully type-safe client controllers and queries\"\n    ],\n    metrics: [\"32ms Average Lookup Latency\", \"99.999% Operational SLA\", \"Zero-Data-Loss Transaction Model\"]\n  },\n  {\n    id: \"hydra-stream\",\n    title: \"Hydra Edge Gateway\",\n    subtitle: \"Enterprise Ingestion Architecture Engine\",\n    desc: \"A highly resilient edge gateway managing 100K+ simultaneous events, running fully on self-healing Kubernetes clusters.\",\n    longDesc: \"An industrial-grade telemetry ingest gateway that handles continuous high-pressure socket weights. It parses packet layers on edge proxies, validates schemas dynamically, and feeds reliable queues with minimal RAM overhead.\",\n    tags: [\"Go\", \"Kubernetes\", \"Kafka\", \"Docker\", \"Prometheus\", \"Terraform\"],\n    category: \"Architecture\",\n    image: \"https://images.unsplash.com/photo-1558494949-ef010cbdcc31?auto=format&fit=crop&w=800&q=80\",\n    features: [\n      \"Self-healing proxy clusters on Kubernetes\",\n      \"Active traffic throttling with custom client credits\",\n      \"Continuous health and packet validation dashboards\",\n      \"Automatic failovers across geo-replicated availability zones\"\n    ],\n    metrics: [\"100K+ Concurrent Telemetries\", \"0.01% Data Ingestion Regressions\", \"Geo-Replicated Failovers Under 2s\"]\n  },\n  {\n    id: \"stellar-kit\",\n    title: \"Stellar Design Core\",\n    subtitle: \"Accessible Enterprise React Assembly Kit\",\n    desc: \"A rigid, highly-crafted, modern accessible React component library built with perfect motion animations and customizable tokens.\",\n    longDesc: \"Stellar Kit compiles beautiful, lightweight custom interactive primitives conforming strictly to WCAG 2.1 AA benchmarks. Its modular tokens allow teams to launch fluid, consistent, and safe interfaces with zero styling regressions.\",\n    tags: [\"React 19\", \"Tailwind CSS\", \"Radix UI\", \"A11y Standards\", \"Framer Motion\"],\n    category: \"Frontend\",\n    image: \"https://images.unsplash.com/photo-1550751827-4bd374c3f58b?auto=format&fit=crop&w=800&q=80\",\n    features: [\n      \"WCAG 2.1 AA Accessibility compliance\",\n      \"Subtle physical springs and drag triggers\",\n      \"Fully typed component token schema\",\n      \"Modular build footprints under 4KB per module\"\n    ],\n    metrics: [\"99.8% Test Assertion Coverage\", \"Sub-4KB Bundle Footprint\", \"Conforms to Rigid WCAG AA Specs\"]\n  }\n];\n\nexport default function ProjectShowcase({ isDarkMode }: ProjectShowcaseProps) {\n  const [selectedCategory, setSelectedCategory] = useState<string>(\"All\");\n  const [activeProject, setActiveProject] = useState<Project | null>(null);\n\n  const categories = [\"All\", \"Fullstack\", \"Frontend\", \"Architecture\", \"AI/WebGL\"];\n\n  const filteredProjects = selectedCategory === \"All\"\n    ? projects\n    : projects.filter(p => p.category === selectedCategory);\n\n  const getCategoryIcon = (cat: string) => {\n    switch (cat) {\n      case \"Fullstack\":\n        return <Layers className=\"w-3.5 h-3.5\" />;\n      case \"Frontend\":\n        return <Monitor className=\"w-3.5 h-3.5\" />;\n      case \"Architecture\":\n        return <Server className=\"w-3.5 h-3.5\" />;\n      case \"AI/WebGL\":\n        return <Cpu className=\"w-3.5 h-3.5\" />;\n      default:\n        return <Filter className=\"w-3.5 h-3.5\" />;\n    }\n  };\n\n  return (\n    <div className=\"w-full\">\n      {/* Filters */}\n      <div className=\"flex flex-col md:flex-row md:items-center justify-between gap-6 mb-10\">\n        <div>\n          <h2 className=\"text-3xl md:text-4xl font-display font-extrabold tracking-tight\">\n            Selected{\" \"}\n            <span className=\"text-transparent bg-clip-text bg-gradient-to-r from-blue-600 to-indigo-500\">\n              Creations\n            </span>\n          </h2>\n          <p className={`text-sm mt-1 ${isDarkMode ? \"text-zinc-400\" : \"text-neutral-600\"}`}>\n            Exploring structural engineering, client interfaces, and creative systems.\n          </p>\n        </div>\n\n        {/* Category Tabs */}\n        <div className={`flex flex-wrap gap-1.5 p-1 rounded-xl border ${\n          isDarkMode ? \"bg-neutral-950/80 border-white/5\" : \"bg-neutral-50 border-black/[0.04]\"\n        }`}>\n          {categories.map(cat => {\n            const isActive = selectedCategory === cat;\n            return (\n              <button\n                key={cat}\n                onClick={() => setSelectedCategory(cat)}\n                className={`flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-xs font-semibold tracking-wide transition-all ${\n                  isActive\n                    ? \"bg-blue-600 text-white shadow-lg shadow-blue-600/20\"\n                    : isDarkMode\n                    ? \"text-zinc-400 hover:text-white hover:bg-white/5\"\n                    : \"text-neutral-600 hover:text-neutral-900 hover:bg-black/5\"\n                }`}\n              >\n                {getCategoryIcon(cat)}\n                {cat}\n              </button>\n            );\n          })}\n        </div>\n      </div>\n\n      {/* Grid of Projects */}\n      <div className=\"grid grid-cols-1 md:grid-cols-2 gap-6\">\n        <AnimatePresence mode=\"popLayout\">\n          {filteredProjects.map((project, index) => (\n            <motion.div\n              key={project.id}\n              layout\n              initial={{ opacity: 0, y: 20 }}\n              animate={{ opacity: 1, y: 0 }}\n              exit={{ opacity: 0, scale: 0.95 }}\n              transition={{ duration: 0.4, delay: index * 0.05 }}\n              className={`group relative rounded-2xl border overflow-hidden cursor-pointer flex flex-col h-[380px] transition-all duration-500 ${\n                isDarkMode\n                  ? \"bg-neutral-950/40 border-white/[0.04] hover:border-blue-500/30\"\n                  : \"bg-white/40 border-black/[0.04] hover:border-blue-500/20\"\n              }`}\n              onClick={() => setActiveProject(project)}\n              whileHover={{ y: -6 }}\n            >\n              {/* Cover Image with Zoom */}\n              <div className=\"relative h-44 overflow-hidden\">\n                <div className=\"absolute inset-0 bg-gradient-to-t from-neutral-950/80 to-transparent z-10\" />\n                <motion.img\n                  src={project.image}\n                  alt={project.title}\n                  className=\"w-full h-full object-cover group-hover:scale-105 transition-transform duration-700\"\n                  loading=\"lazy\"\n                />\n                {/* Category Badge */}\n                <span className=\"absolute top-4 left-4 z-20 text-[9px] font-mono tracking-widest font-bold uppercase bg-blue-600/95 text-white px-2 py-0.5 rounded\">\n                  {project.category}\n                </span>\n              </div>\n\n              {/* Text Body */}\n              <div className=\"p-5 flex-1 flex flex-col justify-between\">\n                <div>\n                  <h3 className=\"text-xl font-display font-bold tracking-tight mb-1 group-hover:text-blue-500 transition-colors\">\n                    {project.title}\n                  </h3>\n                  <p className={`text-xs font-semibold mb-3 ${isDarkMode ? \"text-zinc-500\" : \"text-neutral-400\"}`}>\n                    {project.subtitle}\n                  </p>\n                  <p className={`text-xs line-clamp-3 leading-relaxed ${isDarkMode ? \"text-zinc-400\" : \"text-neutral-600\"}`}>\n                    {project.desc}\n                  </p>\n                </div>\n\n                {/* Tags footer */}\n                <div className=\"flex flex-wrap gap-1 mt-4\">\n                  {project.tags.slice(0, 3).map((t, idx) => (\n                    <span\n                      key={idx}\n                      className={`text-[9px] font-mono px-2 py-0.5 rounded ${\n                        isDarkMode\n                          ? \"bg-white/[0.03] text-zinc-500 border border-white/[0.02]\"\n                          : \"bg-black/[0.02] text-neutral-500 border border-black/[0.02]\"\n                      }`}\n                    >\n                      {t}\n                    </span>\n                  ))}\n                  {project.tags.length > 3 && (\n                    <span className=\"text-[9px] font-mono text-zinc-500 px-1.5 py-0.5\">\n                      +{project.tags.length - 3} more\n                    </span>\n                  )}\n                </div>\n              </div>\n            </motion.div>\n          ))}\n        </AnimatePresence>\n      </div>"
      replacement_content: "const projects: Project[] = [\n  {\n    id: \"mobile-app-dev\",\n    title: \"Mobile App Development\",\n    subtitle: \"High-Performance Cross-Platform Clients\",\n    desc: \"Building robust, native-speed iOS & Android systems using React Native, Kotlin, Swift, and real-time offline-first caching schemas.\",\n    longDesc: \"Architecting zero-latency mobile solutions configured with local secure SQL databases, background synchronization routines, and biometric gatekeepers. Every interface is meticulously compiled for responsive performance, rendering complex state animations fluidly at a solid 120Hz.\",\n    tags: [\"React Native\", \"Swift\", \"Kotlin\", \"SQLite\", \"Framer Motion\", \"Tailwind CSS\"],\n    category: \"Mobile\",\n    image: \"https://images.unsplash.com/photo-1512941937669-90a1b58e7e9c?auto=format&fit=crop&w=800&q=80\",\n    features: [\n      \"Offline-first data replication\",\n      \"High-security local biometrics\",\n      \"Dynamic thread offloading for animations\",\n      \"Sub-20ms event bridge pipelines\"\n    ],\n    metrics: [\"120Hz Fluid Native Frames\", \"99.9% Crash-Free Session SLA\", \"4.8/5 Apple App Store Rating\"]\n  },\n  {\n    id: \"web-app-dev\",\n    title: \"Web Development\",\n    subtitle: \"Low-Latency Distributed API & Frontends\",\n    desc: \"Engineering scalable web apps, high-throughput microservice controllers, cluster databases, and custom rendering engines.\",\n    longDesc: \"Specialized in microservice clusters distributing heavy concurrent load. By combining edge proxies with lazy-initialized database links and custom caching modules, web gateways deliver reliable, low-overhead operations under massive traffic spikes.\",\n    tags: [\"Next.js\", \"Node.js\", \"TypeScript\", \"PostgreSQL\", \"Redis\", \"GraphQL\", \"Docker\"],\n    category: \"Web\",\n    image: \"https://images.unsplash.com/photo-1555066931-4365d14bab8c?auto=format&fit=crop&w=800&q=80\",\n    features: [\n      \"High-concurrency cluster scheduling\",\n      \"Sub-40ms server lookup latency\",\n      \"Robust type-safe RPC controllers\",\n      \"Auto-scaling Docker Swarms\"\n    ],\n    metrics: [\"32ms Average API Response\", \"Handles 50K+ Concurrent Sockets\", \"100% Score on Core Web Vitals\"]\n  },\n  {\n    id: \"design-dev\",\n    title: \"Design\",\n    subtitle: \"Exceptional UI/UX & Visual Engineering\",\n    desc: \"Crafting beautiful human-centric design tokens, high-contrast layouts, smooth kinetic typography, and fluid canvas interactions.\",\n    longDesc: \"Creating modern layout architectures where visual elegance meets technical accessibility. By designing responsive, scalable style guides paired with premium micro-interactions and custom vectors, digital tools evoke a distinctive emotional feel while conforming strictly to WCAG AA benchmarks.\",\n    tags: [\"Figma\", \"Design Systems\", \"WebGL\", \"Framer Motion\", \"CSS Variables\", \"Tailwind CSS\"],\n    category: \"Design\",\n    image: \"https://images.unsplash.com/photo-1561070791-26c113006238?auto=format&fit=crop&w=800&q=80\",\n    features: [\n      \"WCAG 2.1 AA Accessibility compliance\",\n      \"Strictly-typed theme variables\",\n      \"Physical spring animations\",\n      \"Fluid grid layouts & negative space balance\"\n    ],\n    metrics: [\"100% Component Token Compliance\", \"+45% Higher Client Satisfaction\", \"Perfect Responsive Adaptation\"]\n  },\n  {\n    id: \"marketing-dev\",\n    title: \"Digital Marketing\",\n    subtitle: \"Data-Driven Technical Performance Growth\",\n    desc: \"Optimizing conversion funnels, micro-data schemas, technical SEO clusters, and automated analytical telemetry trackers.\",\n    longDesc: \"Driving customer growth through extreme engineering of the marketing stack. This covers SEO cluster nodes, structured schema integrations, and detailed analytics mapping. Every landing site is designed to convert traffic with optimized loading paths and minimal asset footprints.\",\n    tags: [\"SEO Engine\", \"Google Analytics V4\", \"Structured Schema.org\", \"Conversion Funnels\", \"Vitals Optimization\"],\n    category: \"Marketing\",\n    image: \"https://images.unsplash.com/photo-1460925895917-afdab827c52f?auto=format&fit=crop&w=800&q=80\",\n    features: [\n      \"Technical SEO metadata generators\",\n      \"Full analytics tunnel mapping\",\n      \"Sub-second cold-start page rendering\",\n      \"Interactive conversion playgrounds\"\n    ],\n    metrics: [\"+300% Organic Organic Reach\", \"Sub-1s LCP Load Metric\", \"42% Conversion Rate Lift\"]\n  }\n];\n\nexport default function ProjectShowcase({ isDarkMode }: ProjectShowcaseProps) {\n  const [selectedCategory, setSelectedCategory] = useState<string>(\"All\");\n  const [activeProject, setActiveProject] = useState<Project | null>(null);\n\n  const categories = [\"All\", \"Mobile\", \"Web\", \"Design\", \"Marketing\"];\n\n  const filteredProjects = selectedCategory === \"All\"\n    ? projects\n    : projects.filter(p => p.category === selectedCategory);\n\n  const getCategoryIcon = (cat: string) => {\n    switch (cat) {\n      case \"Mobile\":\n        return <Layers className=\"w-3.5 h-3.5\" />;\n      case \"Web\":\n        return <Monitor className=\"w-3.5 h-3.5\" />;\n      case \"Design\":\n        return <Cpu className=\"w-3.5 h-3.5\" />;\n      case \"Marketing\":\n        return <Server className=\"w-3.5 h-3.5\" />;\n      default:\n        return <Filter className=\"w-3.5 h-3.5\" />;\n    }\n  };\n\n  return (\n    <div className=\"w-full\">\n      {/* Filters */}\n      <div className=\"flex flex-col md:flex-row md:items-center justify-between gap-6 mb-12\">\n        <div>\n          <h2 className=\"text-3xl md:text-4xl font-display font-extrabold tracking-tight\">\n            Our Core{\" \"}\n            <span className=\"italic font-serif font-normal text-transparent bg-clip-text bg-gradient-to-r from-blue-600 to-indigo-500\">\n              Disciplines\n            </span>\n          </h2>\n          <p className={`text-sm mt-1 ${isDarkMode ? \"text-zinc-400\" : \"text-neutral-600\"}`}>\n            Architecting next-generation digital experiences across major design and development verticals.\n          </p>\n        </div>\n\n        {/* Category Tabs */}\n        <div className={`flex flex-wrap gap-1.5 p-1 rounded-xl border ${\n          isDarkMode ? \"bg-neutral-950/80 border-white/5\" : \"bg-neutral-50 border-black/[0.04]\"\n        }`}>\n          {categories.map(cat => {\n            const isActive = selectedCategory === cat;\n            return (\n              <button\n                key={cat}\n                onClick={() => setSelectedCategory(cat)}\n                className={`flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-xs font-semibold tracking-wide transition-all ${\n                  isActive\n                    ? \"bg-blue-600 text-white shadow-lg shadow-blue-600/20\"\n                    : isDarkMode\n                    ? \"text-zinc-400 hover:text-white hover:bg-white/5\"\n                    : \"text-neutral-600 hover:text-neutral-900 hover:bg-black/5\"\n                }`}\n              >\n                {getCategoryIcon(cat)}\n                {cat}\n              </button>\n            );\n          })}\n        </div>\n      </div>\n\n      {/* Stacking Cards of Projects exactly like itboomi.com */}\n      <div className=\"flex flex-col gap-12 sm:gap-16 max-w-4xl mx-auto py-8\">\n        <AnimatePresence mode=\"popLayout\">\n          {filteredProjects.map((project, index) => (\n            <motion.div\n              key={project.id}\n              initial={{ opacity: 0, y: 50 }}\n              whileInView={{ opacity: 1, y: 0 }}\n              viewport={{ once: true, margin: \"-100px\" }}\n              transition={{ duration: 0.6, delay: index * 0.1 }}\n              className=\"sticky w-full origin-top\"\n              style={{\n                top: `${110 + index * 24}px`, // Cascading sticky top offset so older cards show a sliver at the top!\n                zIndex: (index + 1) * 10,\n              }}\n            >\n              {/* Real Stacking Card Interior */}\n              <div\n                onClick={() => setActiveProject(project)}\n                className={`group relative rounded-3xl border p-6 sm:p-8 cursor-pointer flex flex-col md:flex-row gap-6 items-stretch shadow-2xl transition-all duration-500 overflow-hidden ${\n                  isDarkMode\n                    ? \"bg-neutral-900/90 border-white/[0.08] hover:border-blue-500/40 shadow-black/80 backdrop-blur-md\"\n                    : \"bg-white/95 border-black/[0.08] hover:border-blue-500/30 shadow-zinc-200/50 backdrop-blur-md\"\n                }`}\n              >\n                {/* Decorative glowing gradient backdrop inside the card */}\n                <div className={`absolute -right-20 -bottom-20 w-80 h-80 rounded-full blur-[100px] pointer-events-none opacity-25 group-hover:opacity-40 transition-opacity duration-700 ${\n                  index % 4 === 0 \n                    ? \"bg-blue-600\" \n                    : index % 4 === 1 \n                    ? \"bg-indigo-600\" \n                    : index % 4 === 2 \n                    ? \"bg-cyan-600\" \n                    : \"bg-blue-50\"\n                }`} />\n\n                {/* Card Left: Content Details */}\n                <div className=\"flex-1 flex flex-col justify-between space-y-6 relative z-10\">\n                  <div className=\"space-y-4\">\n                    {/* Top Row: Index Counter & Category */}\n                    <div className=\"flex items-center justify-between\">\n                      <span className=\"text-sm font-mono font-bold text-blue-500 tracking-wider\">\n                        0{index + 1}\n                      </span>\n                      <span className=\"text-[9px] font-mono tracking-widest font-extrabold uppercase bg-blue-600/10 text-blue-500 px-2.5 py-1 rounded-full border border-blue-500/20\">\n                        {project.category}\n                      </span>\n                    </div>\n\n                    {/* Title & Subtitle */}\n                    <div className=\"space-y-1\">\n                      <h3 className=\"text-2xl sm:text-3xl font-display font-extrabold tracking-tight group-hover:text-blue-400 transition-colors\">\n                        {project.title}\n                      </h3>\n                      <p className={`text-xs font-bold tracking-wide ${isDarkMode ? \"text-zinc-500\" : \"text-neutral-400\"}`}>\n                        {project.subtitle}\n                      </p>\n                    </div>\n\n                    {/* Main short description */}\n                    <p className={`text-xs sm:text-sm leading-relaxed line-clamp-3 ${isDarkMode ? \"text-zinc-400\" : \"text-neutral-600\"}`}>\n                      {project.desc}\n                    </p>\n                  </div>\n\n                  {/* Tags & Performance Metric Highlights */}\n                  <div className=\"space-y-4\">\n                    {/* Core Metrics highlight in pill */}\n                    <div className=\"flex items-center gap-1.5 flex-wrap\">\n                      {project.metrics.slice(0, 1).map((met, mIdx) => (\n                        <div \n                          key={mIdx}\n                          className={`flex items-center gap-1.5 px-3 py-1 rounded-full text-[10px] font-bold ${\n                            isDarkMode ? \"bg-white/[0.03] text-zinc-300 border border-white/5\" : \"bg-black/[0.02] text-neutral-800 border border-black/5\"\n                          }`}\n                        >\n                          <span className=\"w-1.5 h-1.5 rounded-full bg-blue-500\" />\n                          {met}\n                        </div>\n                      ))}\n                    </div>\n\n                    {/* Technology list tags */}\n                    <div className=\"flex flex-wrap gap-1.5\">\n                      {project.tags.slice(0, 4).map((tag, tIdx) => (\n                        <span\n                          key={tIdx}\n                          className={`text-[9px] font-mono px-2 py-0.5 rounded ${\n                            isDarkMode\n                              ? \"bg-white/[0.02] text-zinc-500 border border-white/[0.02]\"\n                              : \"bg-black/[0.01] text-neutral-500 border border-black/[0.01]\"\n                          }`}\n                        >\n                          {tag}\n                        </span>\n                      ))}\n                      {project.tags.length > 4 && (\n                        <span className=\"text-[9px] font-mono text-zinc-500 px-1.5 py-0.5\">\n                          +{project.tags.length - 4} more\n                        </span>\n                      )}\n                    </div>\n                  </div>\n                </div>\n\n                {/* Card Right: Rounded Media Cover Panel with hover Zoom */}\n                <div className=\"w-full md:w-[320px] lg:w-[360px] h-[200px] md:h-auto min-h-[180px] relative rounded-2xl overflow-hidden shadow-inner flex-shrink-0 relative z-10 self-stretch\">\n                  <div className=\"absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent z-10\" />\n                  <motion.img\n                    src={project.image}\n                    alt={project.title}\n                    className=\"w-full h-full object-cover group-hover:scale-105 transition-transform duration-700\"\n                    loading=\"lazy\"\n                  />\n                  \n                  {/* Hover Inspect overlay text */}\n                  <div className=\"absolute bottom-4 right-4 z-20 flex items-center gap-1.5 px-3 py-1.5 rounded-xl bg-black/60 hover:bg-black/80 text-white text-[10px] font-bold tracking-wider uppercase border border-white/10 backdrop-blur-sm transition-colors\">\n                    <ExternalLink className=\"w-3 h-3\" />\n                    Inspect Stack\n                  </div>\n                </div>\n              </div>\n            </motion.div>\n          ))}\n        </AnimatePresence>\n      </div>"
    }
