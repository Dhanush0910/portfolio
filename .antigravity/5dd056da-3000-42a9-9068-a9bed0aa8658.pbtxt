  file_change {
    absolute_path_uri: "file:///src/components/Timeline.tsx"
    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "import { motion } from \"motion/react\";\nimport { useState } from \"react\";\nimport { Experience } from \"../types\";\nimport { Calendar, Briefcase, TrendingUp, Award } from \"lucide-react\";\n\ninterface TimelineProps {\n  isDarkMode: boolean;\n}\n\nconst experiences: Experience[] = [\n  {\n    year: \"2021 \342\200\224 PRESENT\",\n    company: \"ScaleGlobal Labs\",\n    role: \"Principal Systems Architect\",\n    desc: \"Spearheaded migration of decentralized micro-frontends and core high-throughput APIs serving 40M+ daily active sessions. Architected next-gen serverless rendering engine reducing cold starts by 82% and cloud operational spend by $1.4M annually.\",\n    tags: [\"Distributed Systems\", \"WebAssembly\", \"TypeScript\", \"Next.js\", \"Serverless\", \"AWS/GCP\"],\n    duration: \"5 Yrs\",\n    metrics: [\"40M+ Daily Active Sessions\", \"82% Reduction in Cold Starts\", \"$1.4M Cloud Cost Saved\"]\n  },\n  {\n    year: \"2016 \342\200\224 2021\",\n    company: \"CloudNest Inc\",\n    role: \"Lead Fullstack Engineer\",\n    desc: \"Led a remote engineering taskforce of 14 senior developers building enterprise workflow automation software. Introduced rigid type systems, CI/CD visual pipelines, and high-performance React canvases for complex node diagrams.\",\n    tags: [\"React/Redux\", \"Node.js/Express\", \"Docker\", \"GraphQL\", \"Kubernetes\", \"Redis\"],\n    duration: \"5 Yrs\",\n    metrics: [\"14 Engineers Supervised\", \"99.98% System Uptime\", \"300% Platform Scale Increase\"]\n  },\n  {\n    year: \"2011 \342\200\224 2016\",\n    company: \"CoreWeb Systems\",\n    role: \"Senior Software Engineer\",\n    desc: \"Engineered single-page application frameworks and customized analytics engines before standard mainstream client setups became widespread. Optimized core browser layout rendering logic, shaving 2.4s off Average Page Load times.\",\n    tags: [\"Vanilla JS\", \"HTML5/CSS3\", \"WebGL\", \"RESTful APIs\", \"SQL\", \"Web Performance\"],\n    duration: \"5 Yrs\",\n    metrics: [\"Shaved 2.4s Off Page Load\", \"20+ Enterprise Modules\", \"Zero-Regression Lead\"]\n  },\n  {\n    year: \"2006 \342\200\224 2011\",\n    company: \"PixelLab Studios\",\n    role: \"Founding Fullstack Developer\",\n    desc: \"Bootstrapped custom interactive websites, e-commerce engines, and graphic canvases for early web pioneers. Authored modular PHP/MySQL/JavaScript micro-libraries for lighting-fast data retrieval.\",\n    tags: [\"PHP/LAMP\", \"Early JavaScript\", \"MySQL\", \"UI/UX Prototyping\", \"Scalable Databases\"],\n    duration: \"5 Yrs\",\n    metrics: [\"100+ Custom Sites Shipped\", \"Founding Engineer\", \"Micro-Library Author\"]\n  }\n];\n\nexport default function Timeline({ isDarkMode }: TimelineProps) {\n  const [activeExp, setActiveExp] = useState<number | null>(0);\n\n  return (\n    <div className=\"w-full\">\n      {/* Title */}\n      <div className=\"mb-10 text-center md:text-left\">\n        <h2 className=\"text-3xl md:text-4xl font-display font-extrabold tracking-tight\">\n          Crafting Since{\" \"}\n          <span className=\"text-transparent bg-clip-text bg-gradient-to-r from-orange-500 to-amber-400\">\n            2006\n          </span>\n        </h2>\n        <p className={`text-sm mt-2 max-w-lg ${isDarkMode ? \"text-zinc-400\" : \"text-neutral-600\"}`}>\n          A timeline of enterprise architecture, full-stack leadership, and visual refinement over two decades.\n        </p>\n      </div>\n\n      <div className=\"relative border-l border-orange-500/15 pl-6 ml-4 md:ml-6 space-y-12\">\n        {experiences.map((exp, index) => {\n          const isActive = activeExp === index;\n\n          return (\n            <div key={index} className=\"relative group\">\n              {/* Timeline dot marker */}\n              <motion.div\n                className={`absolute -left-[31px] top-1.5 w-4 h-4 rounded-full border-2 transition-all duration-300 flex items-center justify-center ${\n                  isActive\n                    ? \"bg-orange-500 border-orange-500 shadow-[0_0_15px_rgba(249,115,22,0.6)] scale-110\"\n                    : \"bg-neutral-950 border-orange-500/30 group-hover:border-orange-500/60\"\n                }`}\n                animate={{\n                  scale: isActive ? 1.2 : 1,\n                }}\n                onClick={() => setActiveExp(index)}\n              >\n                {isActive && (\n                  <div className=\"w-1.5 h-1.5 rounded-full bg-white\" />\n                )}\n              </motion.div>\n\n              {/* Card Container */}\n              <motion.div\n                className={`p-6 rounded-2xl border transition-all duration-500 cursor-pointer ${\n                  isActive\n                    ? isDarkMode\n                      ? \"bg-neutral-950/90 border-orange-500/30 shadow-2xl shadow-orange-950/5\"\n                      : \"bg-white border-orange-500/20 shadow-xl shadow-orange-500/5\"\n                    : isDarkMode\n                    ? \"bg-neutral-950/40 border-white/[0.04] hover:bg-neutral-950/60 hover:border-white/[0.08]\"\n                    : \"bg-white/60 border-black/[0.04] hover:bg-white/80 hover:border-black/[0.08]\"\n                }`}\n                onClick={() => setActiveExp(index)}\n                whileHover={{ y: -4 }}\n                transition={{ type: \"spring\", stiffness: 300, damping: 20 }}\n              >\n                {/* Header info */}\n                <div className=\"flex flex-col md:flex-row md:items-center justify-between gap-2 mb-4\">\n                  <div>\n                    <span className=\"text-[10px] font-mono tracking-widest text-orange-500 uppercase font-semibold flex items-center gap-1.5\">\n                      <Calendar className=\"w-3.5 h-3.5\" />\n                      {exp.year} ({exp.duration})\n                    </span>\n                    <h3 className=\"text-xl font-display font-bold tracking-tight mt-1\">\n                      {exp.role}\n                    </h3>\n                    <span className={`text-xs font-semibold ${isDarkMode ? \"text-zinc-400\" : \"text-neutral-500\"}`}>\n                      {exp.company}\n                    </span>\n                  </div>\n\n                  {/* Icon Indicator */}\n                  <div className={`p-2.5 rounded-xl self-start md:self-center ${\n                    isActive \n                      ? \"bg-orange-500/10 text-orange-500\" \n                      : \"bg-black/5 dark:bg-white/5 text-zinc-500\"\n                  }`}>\n                    {index === 0 ? (\n                      <Award className=\"w-5 h-5\" />\n                    ) : (\n                      <Briefcase className=\"w-5 h-5\" />\n                    )}\n                  </div>\n                </div>\n\n                {/* Body details */}\n                <p className={`text-sm leading-relaxed mb-6 ${\n                  isActive \n                    ? isDarkMode ? \"text-zinc-300\" : \"text-neutral-700\"\n                    : isDarkMode ? \"text-zinc-400/80\" : \"text-neutral-600/80\"\n                }`}>\n                  {exp.desc}\n                </p>\n\n                {/* Collapsible Impact Metrics Container */}\n                {isActive && (\n                  <motion.div\n                    initial={{ opacity: 0, height: 0 }}\n                    animate={{ opacity: 1, height: \"auto\" }}\n                    exit={{ opacity: 0, height: 0 }}\n                    className=\"border-t border-dashed border-orange-500/20 pt-4 mt-4\"\n                  >\n                    <span className=\"text-[10px] font-mono tracking-widest text-zinc-500 uppercase font-bold flex items-center gap-1.5 mb-3\">\n                      <TrendingUp className=\"w-3 h-3 text-orange-500\" />\n                      KEY IMPACT METRICS\n                    </span>\n                    <div className=\"grid grid-cols-1 sm:grid-cols-3 gap-3\">\n                      {exp.metrics.map((metric, mIdx) => (\n                        <div\n                          key={mIdx}\n                          className={`p-3 rounded-xl border ${\n                            isDarkMode\n                              ? \"bg-zinc-900/40 border-white/[0.04]\"\n                              : \"bg-neutral-50 border-black/[0.04]\"\n                          }`}\n                        >\n                          <span className=\"text-xs font-display font-bold tracking-tight text-orange-500 block\">\n                            {metric.split(\" \")[0]}\n                          </span>\n                          <span className={`text-[10px] leading-tight block mt-0.5 ${\n                            isDarkMode ? \"text-zinc-400\" : \"text-neutral-600\"\n                          }`}>\n                            {metric.split(\" \").slice(1).join(\" \")}\n                          </span>\n                        </div>\n                      ))}\n                    </div>\n                  </motion.div>\n                )}\n\n                {/* Tags */}\n                <div className=\"flex flex-wrap gap-1.5 mt-4\">\n                  {exp.tags.map((tag, tIdx) => (\n                    <span\n                      key={tIdx}\n                      className={`text-[10px] font-mono px-2 py-0.5 rounded-md ${\n                        isActive\n                          ? \"bg-orange-500/10 text-orange-500 dark:text-orange-400 border border-orange-500/20\"\n                          : isDarkMode\n                          ? \"bg-white/[0.02] text-zinc-500 border border-white/[0.02]\"\n                          : \"bg-black/[0.02] text-neutral-500 border border-black/[0.02]\"\n                      }`}\n                    >\n                      {tag}\n                    </span>\n                  ))}\n                </div>\n              </motion.div>\n            </div>\n          );\n        })}\n      </div>\n    </div>\n  );\n}\n"
    }
