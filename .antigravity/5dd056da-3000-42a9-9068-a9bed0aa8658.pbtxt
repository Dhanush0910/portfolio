    replacement_chunks {
      replacement_content: "import { motion } from \"motion/react\";\n\ninterface OrbitalCoreProps {\n  isDarkMode: boolean;\n}\n\nexport default function OrbitalCore({ isDarkMode }: OrbitalCoreProps) {\n  return (\n    <div className=\"relative flex items-center justify-center w-64 h-64 mx-auto z-10 pointer-events-auto\">\n      {/* Background Outer Ambient Glow */}\n      <motion.div\n        className=\"absolute w-52 h-52 rounded-full blur-3xl pointer-events-none\"\n        style={{\n          background: isDarkMode\n            ? \"radial-gradient(circle, rgba(255, 92, 0, 0.28) 0%, transparent 70%)\"\n            : \"radial-gradient(circle, rgba(251, 146, 60, 0.16) 0%, transparent 70%)\",\n        }}\n        animate={{\n          scale: [1, 1.25, 0.9, 1],\n          opacity: [0.6, 0.9, 0.5, 0.6],\n        }}\n        transition={{\n          duration: 8,\n          repeat: Infinity,\n          ease: \"easeInOut\",\n        }}\n      />\n\n      {/* Orbit Track 1 - Outer */}\n      <motion.div\n        className={`absolute rounded-full border-dashed border ${\n          isDarkMode ? \"border-white/5\" : \"border-black/5\"\n        }`}\n        style={{ width: \"240px\", height: \"240px\" }}\n        animate={{ rotate: 360 }}\n        transition={{ duration: 25, repeat: Infinity, ease: \"linear\" }}\n      >\n        {/* Orbital Node 1 */}\n        <div className=\"absolute top-0 left-1/2 -translate-x-1/2 -translate-y-1/2 flex items-center justify-center\">\n          <div className=\"w-2.5 h-2.5 rounded-full bg-orange-500 shadow-[0_0_10px_rgba(249,115,22,0.8)]\" />\n        </div>\n      </motion.div>\n\n      {/* Orbit Track 2 - Middle */}\n      <motion.div\n        className={`absolute rounded-full border ${\n          isDarkMode ? \"border-white/[0.03]\" : \"border-black/[0.03]\"\n        }`}\n        style={{ width: \"190px\", height: \"190px\" }}\n        animate={{ rotate: -360 }}\n        transition={{ duration: 18, repeat: Infinity, ease: \"linear\" }}\n      >\n        {/* Orbital Node 2 */}\n        <div className=\"absolute bottom-6 right-6 flex items-center justify-center\">\n          <div className=\"w-1.5 h-1.5 rounded-full bg-amber-400 shadow-[0_0_8px_rgba(251,191,36,0.8)]\" />\n        </div>\n      </motion.div>\n\n      {/* Primary Glowing Core Sphere */}\n      <motion.div\n        className={`relative flex items-center justify-center w-36 h-36 rounded-full border shadow-2xl transition-all duration-700 ${\n          isDarkMode\n            ? \"bg-neutral-950/95 border-white/[0.08] shadow-[0_0_40px_rgba(255,92,0,0.18)]\"\n            : \"bg-white/95 border-black/[0.06] shadow-[0_0_30px_rgba(255,92,0,0.1)]\"\n        }`}\n        whileHover={{\n          scale: 1.08,\n          boxShadow: isDarkMode \n            ? \"0 0 60px rgba(255, 92, 0, 0.35)\" \n            : \"0 0 40px rgba(255, 92, 0, 0.2)\",\n        }}\n        transition={{ type: \"spring\", stiffness: 200, damping: 15 }}\n      >\n        {/* Concentric glass gradients */}\n        <div className=\"absolute inset-1.5 rounded-full bg-radial from-transparent to-black/[0.04] dark:to-white/[0.02]\" />\n\n        {/* Dual Intersecting Glowing Rings Logo */}\n        <div className=\"relative flex items-center justify-center w-20 h-20\">\n          <motion.div\n            className=\"absolute w-14 h-14 rounded-full border-2 border-orange-500/80 mix-blend-screen\"\n            animate={{\n              rotateX: [60, 60, 60],\n              rotateY: [0, 180, 360],\n              scale: [1, 1.05, 1],\n            }}\n            transition={{\n              duration: 5,\n              repeat: Infinity,\n              ease: \"linear\",\n            }}\n            style={{ transformStyle: \"preserve-3d\" }}\n          />\n          <motion.div\n            className=\"absolute w-14 h-14 rounded-full border-2 border-amber-400/80 mix-blend-screen\"\n            animate={{\n              rotateX: [-60, -60, -60],\n              rotateY: [180, 360, 540],\n              scale: [1.05, 1, 1.05],\n            }}\n            transition={{\n              duration: 5,\n              repeat: Infinity,\n              ease: \"linear\",\n            }}\n            style={{ transformStyle: \"preserve-3d\" }}\n          />\n\n          {/* Central Monogram Badge */}\n          <div className=\"absolute flex flex-col items-center justify-center\">\n            <span className=\"text-xl font-display font-extrabold tracking-widest text-transparent bg-clip-text bg-gradient-to-r from-orange-500 via-amber-400 to-orange-500\">\n              D\n            </span>\n            <span className=\"text-[7px] font-mono tracking-widest text-zinc-500 uppercase\">\n              2006-2026\n            </span>\n          </div>\n        </div>\n\n        {/* Inner shadow/ambient reflection rim */}\n        <div className=\"absolute inset-0 rounded-full border border-white/5 pointer-events-none\" />\n      </motion.div>\n    </div>\n  );\n}\n"
    }
