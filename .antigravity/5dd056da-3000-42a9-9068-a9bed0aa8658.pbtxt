    replacement_chunks {
      target_content: "  return (\n    <div className=\"w-full\">\n      {/* Filters */}\n      <div className=\"flex flex-col md:flex-row md:items-center justify-between gap-6 mb-10\">\n        <div>\n          <h2 className=\"text-3xl md:text-4xl font-display font-extrabold tracking-tight\">\n            Selected{\" \"}\n            <span className=\"text-transparent bg-clip-text bg-gradient-to-r from-orange-500 to-amber-400\">\n              Creations\n            </span>\n          </h2>\n          <p className={`text-sm mt-1 ${isDarkMode ? \"text-zinc-400\" : \"text-neutral-600\"}`}>\n            Exploring structural engineering, client interfaces, and creative systems.\n          </p>\n        </div>\n\n        {/* Category Tabs */}\n        <div className={`flex flex-wrap gap-1.5 p-1 rounded-xl border ${\n          isDarkMode ? \"bg-neutral-950/80 border-white/5\" : \"bg-neutral-50 border-black/[0.04]\"\n        }`}>\n          {categories.map(cat => {\n            const isActive = selectedCategory === cat;\n            return (\n              <button\n                key={cat}\n                onClick={() => setSelectedCategory(cat)}\n                className={`flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-xs font-semibold tracking-wide transition-all ${\n                  isActive\n                    ? \"bg-orange-500 text-white shadow-lg shadow-orange-500/20\"\n                    : isDarkMode\n                    ? \"text-zinc-400 hover:text-white hover:bg-white/5\"\n                    : \"text-neutral-600 hover:text-neutral-900 hover:bg-black/5\"\n                }`}\n              >\n                {getCategoryIcon(cat)}\n                {cat}\n              </button>\n            );\n          })}\n        </div>\n      </div>\n\n      {/* Grid of Projects */}\n      <div className=\"grid grid-cols-1 md:grid-cols-2 gap-6\">\n        <AnimatePresence mode=\"popLayout\">\n          {filteredProjects.map((project, index) => (\n            <motion.div\n              key={project.id}\n              layout\n              initial={{ opacity: 0, y: 20 }}\n              animate={{ opacity: 1, y: 0 }}\n              exit={{ opacity: 0, scale: 0.95 }}\n              transition={{ duration: 0.4, delay: index * 0.05 }}\n              className={`group relative rounded-2xl border overflow-hidden cursor-pointer flex flex-col h-[380px] transition-all duration-500 ${\n                isDarkMode\n                  ? \"bg-neutral-950/40 border-white/[0.04] hover:border-orange-500/30\"\n                  : \"bg-white/40 border-black/[0.04] hover:border-orange-500/20\"\n              }`}\n              onClick={() => setActiveProject(project)}\n              whileHover={{ y: -6 }}\n            >\n              {/* Cover Image with Zoom */}\n              <div className=\"relative h-44 overflow-hidden\">\n                <div className=\"absolute inset-0 bg-gradient-to-t from-neutral-950/80 to-transparent z-10\" />\n                <motion.img\n                  src={project.image}\n                  alt={project.title}\n                  className=\"w-full h-full object-cover group-hover:scale-105 transition-transform duration-700\"\n                  loading=\"lazy\"\n                />\n                {/* Category Badge */}\n                <span className=\"absolute top-4 left-4 z-20 text-[9px] font-mono tracking-widest font-bold uppercase bg-orange-500/95 text-white px-2 py-0.5 rounded\">\n                  {project.category}\n                </span>\n              </div>\n\n              {/* Text Body */}\n              <div className=\"p-5 flex-1 flex flex-col justify-between\">\n                <div>\n                  <h3 className=\"text-xl font-display font-bold tracking-tight mb-1 group-hover:text-orange-500 transition-colors\">\n                    {project.title}\n                  </h3>\n                  <p className={`text-xs font-semibold mb-3 ${isDarkMode ? \"text-zinc-500\" : \"text-neutral-400\"}`}>\n                    {project.subtitle}\n                  </p>\n                  <p className={`text-xs line-clamp-3 leading-relaxed ${isDarkMode ? \"text-zinc-400\" : \"text-neutral-600\"}`}>\n                    {project.desc}\n                  </p>\n                </div>\n\n                {/* Tags footer */}\n                <div className=\"flex flex-wrap gap-1 mt-4\">\n                  {project.tags.slice(0, 3).map((t, idx) => (\n                    <span\n                      key={idx}\n                      className={`text-[9px] font-mono px-2 py-0.5 rounded ${\n                        isDarkMode\n                          ? \"bg-white/[0.03] text-zinc-500 border border-white/[0.02]\"\n                          : \"bg-black/[0.02] text-neutral-500 border border-black/[0.02]\"\n                      }`}\n                    >\n                      {t}\n                    </span>\n                  ))}\n                  {project.tags.length > 3 && (\n                    <span className=\"text-[9px] font-mono text-zinc-500 px-1.5 py-0.5\">\n                      +{project.tags.length - 3} more\n                    </span>\n                  )}\n                </div>\n              </div>\n            </motion.div>\n          ))}\n        </AnimatePresence>\n      </div>\n\n      {/* Immersive Project Drawer/Modal */}\n      <AnimatePresence>\n        {activeProject && (\n          <div className=\"fixed inset-0 z-50 flex items-center justify-center p-4\">\n            {/* Backdrop */}\n            <motion.div\n              initial={{ opacity: 0 }}\n              animate={{ opacity: 1 }}\n              exit={{ opacity: 0 }}\n              onClick={() => setActiveProject(null)}\n              className=\"absolute inset-0 bg-black/80 backdrop-blur-sm\"\n            />\n\n            {/* Modal Box */}\n            <motion.div\n              initial={{ scale: 0.95, opacity: 0, y: 15 }}\n              animate={{ scale: 1, opacity: 1, y: 0 }}\n              exit={{ scale: 0.95, opacity: 0, y: 15 }}\n              transition={{ type: \"spring\", stiffness: 260, damping: 25 }}\n              className={`relative w-full max-w-2xl rounded-2xl border overflow-hidden shadow-2xl z-10 flex flex-col max-h-[85vh] ${\n                isDarkMode\n                  ? \"bg-neutral-950 border-white/[0.08] text-white\"\n                  : \"bg-white border-black/[0.08] text-neutral-900\"\n              }`}\n            >\n              {/* Header Image banner */}\n              <div className=\"relative h-56 overflow-hidden\">\n                <div className=\"absolute inset-0 bg-gradient-to-t from-neutral-950 via-neutral-950/30 to-transparent z-10\" />\n                <img\n                  src={activeProject.image}\n                  alt={activeProject.title}\n                  className=\"w-full h-full object-cover\"\n                />\n                <button\n                  onClick={() => setActiveProject(null)}\n                  className=\"absolute top-4 right-4 z-20 p-2 rounded-full bg-black/60 hover:bg-black/80 text-white transition-all border border-white/5\"\n                >\n                  <X className=\"w-4 h-4\" />\n                </button>\n\n                {/* Floating identity inside banner */}\n                <div className=\"absolute bottom-4 left-5 z-20\">\n                  <span className=\"text-[9px] font-mono tracking-widest font-extrabold uppercase bg-orange-500 text-white px-2 py-0.5 rounded\">\n                    {activeProject.category}\n                  </span>\n                  <h3 className=\"text-2xl md:text-3xl font-display font-extrabold tracking-tight text-white mt-1.5\">\n                    {activeProject.title}\n                  </h3>\n                  <p className=\"text-xs font-semibold text-zinc-300 mt-0.5\">\n                    {activeProject.subtitle}\n                  </p>\n                </div>\n              </div>\n\n              {/* Scrollable details */}\n              <div className=\"p-6 overflow-y-auto space-y-6\">\n                <div>\n                  <h4 className=\"text-xs font-mono tracking-widest text-orange-500 font-bold uppercase mb-2\">\n                    ARCHITECTURAL DETAILS\n                  </h4>\n                  <p className={`text-sm leading-relaxed ${isDarkMode ? \"text-zinc-300\" : \"text-neutral-700\"}`}>\n                    {activeProject.longDesc}\n                  </p>\n                </div>\n\n                {/* Features & Metrics Grid */}\n                <div className=\"grid grid-cols-1 sm:grid-cols-2 gap-5\">\n                  {/* Key Features */}\n                  <div>\n                    <h4 className=\"text-xs font-mono tracking-widest text-orange-500 font-bold uppercase mb-2\">\n                      CORE CAPABILITIES\n                    </h4>\n                    <ul className=\"space-y-1.5\">\n                      {activeProject.features.map((feature, fIdx) => (\n                        <li key={fIdx} className=\"text-xs flex items-start gap-2\">\n                          <span className=\"w-1.5 h-1.5 rounded-full bg-orange-500 mt-1.5 flex-shrink-0\" />\n                          <span className={isDarkMode ? \"text-zinc-400\" : \"text-neutral-600\"}>{feature}</span>\n                        </li>\n                      ))}\n                    </ul>\n                  </div>\n\n                  {/* Impact metrics */}\n                  <div>\n                    <h4 className=\"text-xs font-mono tracking-widest text-orange-500 font-bold uppercase mb-2\">\n                      ENGINEERING OUTCOMES\n                    </h4>\n                    <ul className=\"space-y-1.5\">\n                      {activeProject.metrics.map((metric, mIdx) => (\n                        <li key={mIdx} className=\"text-xs flex items-start gap-2\">\n                          <span className=\"w-1.5 h-1.5 rounded-full bg-amber-400 mt-1.5 flex-shrink-0\" />\n                          <span