  file_change {
    absolute_path_uri: "file:///src/components/Terminal.tsx"
    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "import { useState, useRef, useEffect } from \"react\";\nimport { Terminal as TerminalIcon, CornerDownLeft, Play, RefreshCw } from \"lucide-react\";\n\ninterface TerminalProps {\n  isDarkMode: boolean;\n}\n\ninterface LogEntry {\n  command: string;\n  output: string | React.ReactNode;\n}\n\nexport default function Terminal({ isDarkMode }: TerminalProps) {\n  const [input, setInput] = useState(\"\");\n  const [logs, setLogs] = useState<LogEntry[]>([\n    {\n      command: \"system-init\",\n      output: (\n        <div className=\"space-y-1\">\n          <p className=\"text-orange-500 font-bold\">RECOGNITO TERMINAL CORE [v4.1.20]</p>\n          <p className=\"text-zinc-500\">Initializing 20-year full-stack environment...</p>\n          <p className=\"text-zinc-400\">Type <span className=\"text-amber-400\">help</span> to explore console systems, or click the quick-run pills below.</p>\n        </div>\n      )\n    }\n  ]);\n\n  const bottomRef = useRef<HTMLDivElement>(null);\n  const inputRef = useRef<HTMLInputElement>(null);\n\n  // Auto-scroll on logs expansion\n  useEffect(() => {\n    bottomRef.current?.scrollIntoView({ behavior: \"smooth\" });\n  }, [logs]);\n\n  const handleCommand = (rawCommand: string) => {\n    const cmd = rawCommand.trim().toLowerCase();\n    if (!cmd) return;\n\n    let output: string | React.ReactNode = \"\";\n\n    switch (cmd) {\n      case \"help\":\n        output = (\n          <div className=\"grid grid-cols-2 gap-2 text-xs py-1\">\n            <p><span className=\"text-orange-500 font-semibold\">about</span> \342\200\224 Bio summary & craft details</p>\n            <p><span className=\"text-orange-500 font-semibold\">skills</span> \342\200\224 Visual ratings on major stacks</p>\n            <p><span className=\"text-orange-500 font-semibold\">projects</span> \342\200\224 Active micro-service listings</p>\n            <p><span className=\"text-orange-500 font-semibold\">contact</span> \342\200\224 Coordinate access links</p>\n            <p><span className=\"text-orange-500 font-semibold\">clear</span> \342\200\224 Wipe command prompt logs</p>\n          </div>\n        );\n        break;\n\n      case \"about\":\n        output = (\n          <p className=\"leading-relaxed\">\n            I am Dhanush, a Principal Engineer & Systems Architect with 20 years of real-world production experience. Specialized in structuring high-performance distributed microservices, rendering engines, and accessible design system systems. My ethos lies in executing rigid architectural consistency with visually rich pixel control.\n          </p>\n        );\n        break;\n\n      case \"skills\":\n        output = (\n          <div className=\"space-y-1.5 text-xs\">\n            <p className=\"text-amber-400 font-semibold\">SYSTEM STACK CAPABILITY MATRIX:</p>\n            <div className=\"grid grid-cols-1 sm:grid-cols-2 gap-x-6 gap-y-1\">\n              <div>\n                <p>\342\232\241 Frontend (React/Wasm/GL) <span className=\"text-orange-500\">[98%]</span></p>\n                <div className=\"w-full bg-zinc-800 h-1 rounded overflow-hidden mt-0.5\">\n                  <div className=\"bg-orange-500 h-full w-[98%]\" />\n                </div>\n              </div>\n              <div>\n                <p>\342\232\231\357\270\217 Backend Systems (Node/Go) <span className=\"text-orange-500\">[95%]</span></p>\n                <div className=\"w-full bg-zinc-800 h-1 rounded overflow-hidden mt-0.5\">\n                  <div className=\"bg-orange-500 h-full w-[95%]\" />\n                </div>\n              </div>\n              <div>\n                <p>\360\237\217\227\357\270\217 Architecture (K8s/Docker) <span className=\"text-orange-500\">[92%]</span></p>\n                <div className=\"w-full bg-zinc-800 h-1 rounded overflow-hidden mt-0.5\">\n                  <div className=\"bg-orange-500 h-full w-[92%]\" />\n                </div>\n              </div>\n              <div>\n                <p>\360\237\223\246 Devops & Scale (Serverless) <span className=\"text-orange-500\">[94%]</span></p>\n                <div className=\"w-full bg-zinc-800 h-1 rounded overflow-hidden mt-0.5\">\n                  <div className=\"bg-orange-500 h-full w-[94%]\" />\n                </div>\n              </div>\n            </div>\n          </div>\n        );\n        break;\n\n      case \"projects\":\n        output = (\n          <div className=\"space-y-1 text-xs\">\n            <p>\360\237\223\201 <span className=\"text-orange-500 font-bold\">recognito-slat-web</span> \342\200\224 Creative GL rendering (WebGL/Shaders)</p>\n            <p>\360\237\223\201 <span className=\"text-orange-500 font-bold\">omnisearch-hub</span> \342\200\224 Concurrency indexer (Redis/Go/Elastic)</p>\n            <p>\360\237\223\201 <span className=\"text-orange-500 font-bold\">hydra-stream-core</span> \342\200\224 Video telemetry edge (K8s/Kafka)</p>\n          </div>\n        );\n        break;\n\n      case \"contact\":\n        output = (\n          <div className=\"space-y-1\">\n            <p>\360\237\223\247 Email: <span className=\"text-orange-400\">dhanush102003@gmail.com</span></p>\n            <p>\360\237\220\231 GitHub: <a href=\"https://github.com/dhanush102003\" target=\"_blank\" rel=\"noreferrer\" className=\"text-amber-400 underline hover:text-amber-300\">github.com/dhanush102003</a></p>\n            <p>\360\237\222\274 LinkedIn: <a href=\"https://linkedin.com\" target=\"_blank\" rel=\"noreferrer\" className=\"text-amber-400 underline hover:text-amber-300\">dhanush-senior-dev</a></p>\n          </div>\n        );\n        break;\n\n      case \"clear\":\n        setLogs([]);\n        setInput(\"\");\n        return;\n\n      default:\n        output = `Command not recognized: \"${cmd}\". Type \"help\" for system logs.`;\n    }\n\n    setLogs(prev => [...prev, { command: rawCommand, output }]);\n    setInput(\"\");\n  };\n\n  const handleQuickRun = (cmd: string) => {\n    handleCommand(cmd);\n  };\n\n  return (\n    <div className={`w-full rounded-2xl border flex flex-col h-[400px] overflow-hidden font-mono text-xs shadow-2xl transition-all duration-700 ${\n      isDarkMode \n        ? \"bg-neutral-950/95 border-white/[0.08] text-zinc-300 shadow-black/80\" \n        : \"bg-zinc-900 border-zinc-950 text-zinc-300 shadow-neutral-400\"\n    }`}>\n      {/* Terminal Title Bar */}\n      <div className=\"flex items-center justify-between px-5 py-3 border-b border-white/[0.05] bg-black/40\">\n        <div className=\"flex items-center gap-1.5\">\n          <div className=\"w-2.5 h-2.5 rounded-full bg-red-500\" />\n          <div className=\"w-2.5 h-2.5 rounded-full bg-yellow-500\" />\n          <div className=\"w-2.5 h-2.5 rounded-full bg-green-500\" />\n          <span className=\"text-[10px] text-zinc-500 ml-2 uppercase font-semibold flex items-center gap-1.5\">\n            <TerminalIcon className=\"w-3.5 h-3.5 text-orange-500\" />\n            recognito@developer-node: ~\n          </span>\n        </div>\n        <div className=\"text-[9px] text-zinc-600 font-bold tracking-widest uppercase\">\n          STABLE SHELL\n        </div>\n      </div>\n\n      {/* Screen logs area */}\n      <div className=\"flex-1 p-5 overflow-y-auto space-y-4 scrollbar-thin scrollbar-thumb-zinc-800\">\n        {logs.map((log, idx) => (\n          <div key={idx} className=\"space-y-1\">\n            {log.command !== \"system-init\" && (\n              <div className=\"flex items-center gap-1 text-orange-400\">\n                <span>&gt;</span>\n                <span className=\"font-semibold\">{log.command}</span>\n              </div>\n            )}\n            <div className=\"text-zinc-300 leading-relaxed font-normal\">{log.output}</div>\n          </div>\n        ))}\n        <div ref={bottomRef} />\n      </div>\n\n      {/* Quick click command pills */}\n      <div className=\"px-5 py-2.5 bg-black/20 border-t border-white/[0.03] flex flex-wrap gap-1.5 items-center\">\n        <span className=\"text-[10px] text-zinc-500 font-semibold uppercase mr-1 flex items-center gap-1\">\n          <Play className=\"w-2.5 h-2.5\" /> Quick Execute:\n        </span>\n        {[\"about\", \"skills\", \"projects\", \"contact\", \"clear\"].map(cmd => (\n          <button\n            key={cmd}\n            onClick={() => handleQuickRun(cmd)}\n            className=\"px-2 py-0.5 rounded bg-white/5 hover:bg-orange-500/10 hover:text-orange-400 border border-white/5 hover:border-orange-500/20 text-[10px] font-semibold text-zinc-400 transition-all cursor-pointer\"\n          >\n            {cmd}\n          </button>\n        ))}\n      </div>\n\n      {/* Prompt input bar */}\n      <form\n        onSubmit={(e) => {\n          e.preventDefault();\n          handleCommand(input);\n        }}\n        className=\"flex items-center px-5 py-3 border-t border-white/[0.05] bg-black/35\"\n      >\n        <span className=\"text-orange-500 font-bold mr-2\">&gt;</span>\n        <input\n          ref={inputRef}\n          type=\"text\"\n          value={input}\n          onChange={(e) => setInput(e.target.value)}\n          placeholder=\"Type a command (e.g. skills)...\"\n          className=\"flex-1 bg-transparent border-none outline-none focus:ring-0 text-white placeholder-zinc-600 font-mono text-xs\"\n        />\n        <button\n          type=\"submit\"\n          className=\"p-1 text-zinc-500 hover:text-orange-500 transition-colors\"\n        >\n          <CornerDownLeft className=\"w-4 h-4\" />\n        </button>\n      </form>\n    </div>\n  );\n}\n"
