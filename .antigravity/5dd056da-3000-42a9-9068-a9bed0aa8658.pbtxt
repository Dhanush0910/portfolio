    instruction: "Update ContactCard colors to electric blue/indigo theme"
    replacement_infos {
      original_chunk {
        target_content: "    <div className={`w-full rounded-2xl border p-6 md:p-8 relative overflow-hidden transition-all duration-700 ${\n      isDarkMode\n        ? \"bg-neutral-950/90 border-white/[0.08] shadow-2xl\"\n        : \"bg-white border-black/[0.06] shadow-xl\"\n    }`}>\n      {/* Background ambient lighting */}\n      <div className=\"absolute top-0 right-0 w-32 h-32 rounded-full bg-orange-500/10 blur-2xl pointer-events-none\" />\n\n      <div className=\"relative z-10\">\n        <div className=\"mb-6\">\n          <span className=\"text-[10px] font-mono tracking-widest text-orange-500 font-bold uppercase block mb-1\">\n            NETWORK PROTOCOL\n          </span>\n          <h2 className=\"text-2xl md:text-3xl font-display font-extrabold tracking-tight\">\n            Initiate{\" \"}\n            <span className=\"text-transparent bg-clip-text bg-gradient-to-r from-orange-500 to-amber-400\">\n              Transmission\n            </span>\n          </h2>\n          <p className={`text-xs mt-1 ${isDarkMode ? \"text-zinc-400\" : \"text-neutral-500\"}`}>\n            Secure socket contact interface for technical consulting, software auditing, or architectural leadership.\n          </p>\n        </div>\n\n        <AnimatePresence mode=\"wait\">\n          {status === \'success\' ? (\n            <motion.div\n              initial={{ scale: 0.95, opacity: 0 }}\n              animate={{ scale: 1, opacity: 1 }}\n              exit={{ scale: 0.95, opacity: 0 }}\n              className=\"py-12 flex flex-col items-center justify-center text-center\"\n            >\n              <motion.div\n                initial={{ rotate: -45, scale: 0.8 }}\n                animate={{ rotate: 0, scale: 1 }}\n                className=\"w-16 h-16 rounded-full bg-orange-500/10 border border-orange-500/30 flex items-center justify-center text-orange-500 mb-4 shadow-[0_0_20px_rgba(249,115,22,0.2)]\"\n              >\n                <CheckCircle className=\"w-8 h-8\" />\n              </motion.div>\n              <h3 className=\"text-lg font-display font-bold\">Transmission Complete</h3>\n              <p className={`text-xs mt-2 max-w-sm mx-auto leading-relaxed ${isDarkMode ? \"text-zinc-400\" : \"text-neutral-500\"}`}>\n                Your payload was successfully signed and routed. I will initiate response contact within 12 standard business cycles.\n              </p>\n              <button\n                onClick={() => setStatus(\'idle\')}\n                className=\"mt-6 px-4 py-2 rounded-xl text-xs font-semibold bg-orange-500 hover:bg-orange-600 text-white shadow-lg shadow-orange-500/10 transition-all cursor-pointer\"\n              >\n                New Session\n              </button>\n            </motion.div>\n          ) : (\n            <motion.form\n              onSubmit={handleSubmit}\n              initial={{ opacity: 0 }}\n              animate={{ opacity: 1 }}\n              className=\"space-y-4\"\n            >\n              {/* Name & Email Row */}\n              <div className=\"grid grid-cols-1 sm:grid-cols-2 gap-4\">\n                <div className=\"space-y-1\">\n                  <label className=\"text-[10px] font-mono font-bold text-zinc-500 uppercase tracking-widest block\">\n                    IDENTITY NODE\n                  </label>\n                  <div className=\"relative\">\n                    <User className=\"absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-zinc-600\" />\n                    <input\n                      required\n                      type=\"text\"\n                      placeholder=\"e.g. Satoshi\"\n                      value={formData.name}\n                      onChange={(e) => setFormData(prev => ({ ...prev, name: e.target.value }))}\n                      className={`w-full text-xs pl-10 pr-4 py-2.5 rounded-xl border focus:outline-none transition-all ${\n                        isDarkMode\n                          ? \"bg-neutral-900 border-white/[0.06] text-white focus:border-orange-500/50\"\n                          : \"bg-neutral-50 border-black/[0.06] text-neutral-900 focus:border-orange-500/40\"\n                      }`}\n                    />\n                  </div>\n                </div>\n\n                <div className=\"space-y-1\">\n                  <label className=\"text-[10px] font-mono font-bold text-zinc-500 uppercase tracking-widest block\">\n                    ROUTING EMAIL\n                  </label>\n                  <div className=\"relative\">\n                    <Mail className=\"absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-zinc-600\" />\n                    <input\n                      required\n                      type=\"email\"\n                      placeholder=\"e.g. name@network.com\"\n                      value={formData.email}\n                      onChange={(e) => setFormData(prev => ({ ...prev, email: e.target.value }))}\n                      className={`w-full text-xs pl-10 pr-4 py-2.5 rounded-xl border focus:outline-none transition-all ${\n                        isDarkMode\n                          ? \"bg-neutral-900 border-white/[0.06] text-white focus:border-orange-500/50\"\n                          : \"bg-neutral-50 border-black/[0.06] text-neutral-900 focus:border-orange-500/40\"\n                      }`}\n                    />\n                  </div>\n                </div>\n              </div>\n\n              {/* Budget selector */}\n              <div className=\"space-y-1\">\n                <label className=\"text-[10px] font-mono font-bold text-zinc-500 uppercase tracking-widest block\">\n                  BUDGET PROJECTION\n                </label>\n                <div className=\"flex flex-wrap gap-2\">\n                  {budgets.map(b => {\n                    const isSelected = formData.budget === b;\n                    return (\n                      <button\n                        key={b}\n                        type=\"butto