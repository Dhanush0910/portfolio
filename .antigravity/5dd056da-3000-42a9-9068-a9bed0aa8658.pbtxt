      replacement_content: "      {/* Hero View with Parallax Marquees and Letter-by-Letter Reveal */}\n      <section\n        id=\"hero\"\n        className=\"relative min-h-[90vh] flex flex-col items-center justify-center px-4 overflow-hidden pt-12 md:pt-0\"\n      >\n        {/* Parallax Background Typographic Ribbons */}\n        <div className=\"absolute inset-0 flex flex-col justify-center pointer-events-none select-none overflow-hidden opacity-[0.025] dark:opacity-[0.04] z-0\">\n          <motion.div \n            style={{ x: marqueeX }} \n            className=\"text-[12vw] font-display font-black uppercase tracking-widest text-zinc-500 whitespace-nowrap leading-none\"\n          >\n            PRINCIPAL ARCHITECT \342\200\242 FULLSTACK ENGINEER \342\200\242 CREATIVE DEVELOPER \342\200\242 PRINCIPAL ARCHITECT \342\200\242 FULLSTACK ENGINEER \342\200\242 CREATIVE DEVELOPER \342\200\242\n          </motion.div>\n          <motion.div \n            style={{ x: marqueeReverseX }} \n            className=\"text-[12vw] font-display font-black uppercase tracking-widest text-zinc-500 whitespace-nowrap leading-none mt-8\"\n          >\n            SYSTEM CRAFTSMAN \342\200\242 ENTERPRISE SCALE \342\200\242 HIGH CONCURRENCY \342\200\242 SYSTEM CRAFTSMAN \342\200\242 ENTERPRISE SCALE \342\200\242 HIGH CONCURRENCY \342\200\242\n          </motion.div>\n        </div>\n\n        <div className=\"max-w-4xl mx-auto text-center space-y-8 relative z-10 flex flex-col items-center\">\n          \n          {/* Subtle Pill Badge */}\n          <motion.div\n            initial={{ opacity: 0, y: -15 }}\n            animate={isLoaded ? { opacity: 1, y: 0 } : { opacity: 0, y: -15 }}\n            transition={{ duration: 0.6, delay: 0.2, ease: \"easeOut\" }}\n            className={`flex items-center gap-2 px-3 py-1 rounded-full border text-[11px] font-semibold tracking-wider uppercase backdrop-blur-md ${\n              isDarkMode \n                ? \"bg-white/[0.03] border-white/5 text-blue-400\" \n                : \"bg-black/[0.02] border-black/5 text-blue-600\"\n            }`}\n          >\n            <Sparkles className=\"w-3.5 h-3.5\" />\n            20 YEARS OF INDUSTRY CRAFT\n          </motion.div>\n\n          {/* Hero Main Heading with letter-by-letter kinetic spring reveal */}\n          <div className=\"space-y-4\">\n            <h1 className=\"text-5xl sm:text-7xl md:text-8xl font-display font-extrabold tracking-tight leading-[1.05] flex flex-wrap justify-center gap-x-4\">\n              <span className=\"inline-flex overflow-hidden py-2\">\n                {Array.from(\"Meet\").map((char, i) => (\n                  <motion.span\n                    key={`meet-${i}`}\n                    className={`inline-block origin-bottom ${isDarkMode ? \"text-white\" : \"text-neutral-900\"}`}\n                    initial={{ y: \"100%\", rotate: 15 }}\n                    animate={isLoaded ? { y: 0, rotate: 0 } : { y: \"100%\", rotate: 15 }}\n                    transition={{\n                      duration: 0.8,\n                      delay: 0.3 + i * 0.04,\n                      ease: [0.16, 1, 0.3, 1]\n                    }}\n                  >\n                    {char}\n                  </motion.span>\n                ))}\n              </span>\n              <span className=\"inline-flex overflow-hidden py-2\">\n                {Array.from(\"Dhanush\").map((char, i) => (\n                  <motion.span\n                    key={`dhanush-${i}`}\n                    className=\"inline-block origin-bottom italic font-serif font-normal text-transparent bg-clip-text bg-gradient-to-r from-blue-500 via-indigo-400 to-blue-500 cursor-default\"\n                    initial={{ y: \"100%\", rotate: -15, scale: 0.85 }}\n                    animate={isLoaded ? { y: 0, rotate: 0, scale: 1 } : { y: \"100%\", rotate: -15, scale: 0.85 }}\n                    transition={{\n                      duration: 0.9,\n                      delay: 0.5 + i * 0.05,\n                      ease: [0.16, 1, 0.3, 1]\n                    }}\n                    whileHover={{\n                      scale: 1.18,\n                      rotate: 5,\n                      filter: \"brightness(1.2)\",\n                      transition: { duration: 0.2, type: \"spring\", stiffness: 300 }\n                    }}\n                  >\n                    {char}\n                  </motion.span>\n                ))}\n              </span>\n            </h1>\n\n            <motion.p\n              initial={{ opacity: 0, y: 15 }}\n              animate={isLoaded ? { opacity: 1, y: 0 } : { opacity: 0, y: 15 }}\n              transition={{ duration: 0.8, delay: 0.8, ease: \"easeOut\" }}\n              className={`text-lg sm:text-2xl font-light max-w-2xl mx-auto tracking-normal font-sans ${\n                isDarkMode ? \"text-zinc-400\" : \"text-neutral-600\"\n              }`}\n            >\n              Principal Architect & Fullstack Craftsman building secure, high-concurrency enterprise ecosystems.\n            </motion.p>\n          </div>\n\n          {/* Orbital Core Centerpiece (Avatar Sphere) */}\n          <motion.div\n            initial={{ opacity: 0, scale: 0.85 }}\n            animate={isLoaded ? { opacity: 1, scale: 1 } : { opacity: 0, scale: 0.85 }}\n            transition={{ duration: 1, delay: 0.9 }}\n            className=\"py-4\"\n          >\n            <OrbitalCore isDarkMode={isDarkMode} />\n          </motion.div>\n\n          {/* Hero CTA buttons */}\n          <motion.div\n            initial={{ opacity: 0, y: 15 }}\n            animate={isLoaded ? { opacity: 1, y: 0 } : { opacity: 0, y: 15 }}\n            transition={{ duration: 0.8, delay: 1.1 }}\n            className=\"flex flex-col sm:flex-row items-center gap-4 pt-4 relative z-20\"\n          >\n            <button\n              onClick={() => {\n                const element = document.getElementById(\"projects\");\n                element?.scrollIntoView({ behavior: \"smooth\", block: \"start\" });\n              }}\n              className=\"flex items-center gap-2 px-6 py-3 rounded-full bg-blue-600 hover:bg-blue-700 text-white font-bold text-xs tracking-wider uppercase transition-all shadow-lg shadow-blue-600/10 cursor-pointer\"\n            >\n              Inspect Creations\n              <ArrowRight className=\"w-4 h-4\" />\n            </button>\n            <button\n              onClick={() => {\n                const element = document.getElementById(\"terminal\");\n                element?.scrollIntoView({ behavior: \"smooth\", block: \"center\" });\n              }}\n              className={`flex items-center gap-2 px-6 py-3 rounded-full border font-bold text-xs tracking-wider uppercase transition-all cursor-pointer ${\n                isDarkMode\n                  ? \"bg-white/[0.02] border-white/10 hover:border-white/25 text-white\"\n                  : \"bg-black/[0.01] border-black/10 hover:border-black/25 text-neutral-800\"\n              }`}\n            >\n              <TerminalIcon className=\"w-4 h-4\" />\n              Interactive Shell\n            </button>\n          </motion.div>\n\n          {/* Scroll Down Hint */}\n          <motion.div\n            animate={{ y: [0, 8, 0] }}\n            transition={{ duration: 2, repeat: Infinity }}\n            className=\"pt-12 cursor-pointer opacity-50 hover:opacity-100 transition-opacity\"\n            onClick={() => {\n              const element = document.getElementById(\"timeline\");\n              element?.scrollIntoView({ behavior: \"smooth\", block: \"start\" });\n            }}\n          >\n            <ChevronDown className=\"w-5 h-5 text-blue-500\" />\n          </motion.div>\n        </div>\n      </section>"
