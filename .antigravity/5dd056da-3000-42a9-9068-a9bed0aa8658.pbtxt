    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "import { motion } from \"motion/react\";\nimport { Sun, Moon, Sparkles, Code, Menu, X } from \"lucide-react\";\nimport { useState } from \"react\";\n\ninterface HeaderProps {\n  isDarkMode: boolean;\n  setIsDarkMode: (val: boolean) => void;\n  activeSection: string;\n  setActiveSection: (val: string) => void;\n}\n\nexport default function Header({\n  isDarkMode,\n  setIsDarkMode,\n  activeSection,\n  setActiveSection,\n}: HeaderProps) {\n  const [mobileMenuOpen, setMobileMenuOpen] = useState(false);\n\n  const menuItems = [\n    { label: \"Core\", id: \"hero\" },\n    { label: \"Experience\", id: \"timeline\" },\n    { label: \"Creations\", id: \"projects\" },\n    { label: \"Console\", id: \"terminal\" },\n    { label: \"Contact\", id: \"contact\" },\n  ];\n\n  const handleScrollTo = (id: string) => {\n    setActiveSection(id);\n    setMobileMenuOpen(false);\n    const element = document.getElementById(id);\n    if (element) {\n      element.scrollIntoView({ behavior: \"smooth\", block: \"center\" });\n    }\n  };\n\n  return (\n    <header className=\"sticky top-0 z-40 w-full px-4 py-4 md:py-6 pointer-events-none\">\n      <div className=\"max-w-7xl mx-auto flex items-center justify-between pointer-events-auto\">\n        {/* Logo Monogram */}\n        <div\n          onClick={() => handleScrollTo(\"hero\")}\n          className=\"flex items-center gap-2 cursor-pointer group\"\n        >\n          {/* Overlapping Logo Glyphs */}\n          <div className=\"relative w-7 h-7 flex items-center justify-center\">\n            <div className=\"absolute w-5 h-5 rounded-full bg-orange-500/80 mix-blend-screen shadow-[0_0_10px_rgba(249,115,22,0.8)]\" />\n            <div className=\"absolute w-5 h-5 rounded-full bg-zinc-600/80 translate-x-2 mix-blend-screen\" />\n          </div>\n          <span className=\"text-sm font-display font-extrabold tracking-widest text-white uppercase ml-3 drop-shadow-md\">\n            RECOGNITO\n          </span>\n        </div>\n\n        {/* Central Glassmorphic Navigation Capsule */}\n        <nav\n          className={`hidden md:flex items-center gap-1.5 px-4 py-1.5 rounded-full border backdrop-blur-md transition-all duration-700 ${\n            isDarkMode\n              ? \"bg-neutral-950/40 border-white/[0.05]\"\n              : \"bg-white/80 border-black/[0.04]\"\n          }`}\n        >\n          {menuItems.map((item) => {\n            const isActive = activeSection === item.id;\n            return (\n              <button\n                key={item.id}\n                onClick={() => handleScrollTo(item.id)}\n                className={`px-3.5 py-1 rounded-full text-xs font-semibold tracking-wide transition-all relative cursor-pointer`}\n              >\n                {isActive && (\n                  <motion.div\n                    layoutId=\"activeTabGlow\"\n                    className=\"absolute inset-0 rounded-full bg-orange-500/10 border border-orange-500/20\"\n                    transition={{ type: \"spring\", stiffness: 380, damping: 30 }}\n                  />\n                )}\n                <span\n                  className={\n                    isActive\n                      ? \"text-orange-500 font-bold\"\n                      : isDarkMode\n                      ? \"text-zinc-400 hover:text-white\"\n                      : \"text-neutral-600 hover:text-neutral-900\"\n                  }\n                >\n                  {item.label}\n                </span>\n              </button>\n            );\n          })}\n        </nav>\n\n        {/* Right Action buttons */}\n        <div className=\"flex items-center gap-3\">\n          {/* Dark Mode Toggle */}\n          <motion.button\n            onClick={() => setIsDarkMode(!isDarkMode)}\n            className={`p-2 rounded-xl border backdrop-blur-sm cursor-pointer transition-colors ${\n              isDarkMode\n                ? \"bg-neutral-950/40 border-white/[0.05] text-amber-400 hover:text-amber-300\"\n                : \"bg-white/80 border-black/[0.06] text-orange-500 hover:text-orange-600\"\n            }`}\n            whileTap={{ scale: 0.92 }}\n            whileHover={{ scale: 1.05 }}\n          >\n            {isDarkMode ? <Sun className=\"w-4 h-4\" /> : <Moon className=\"w-4 h-4\" />}\n          </motion.button>\n\n          {/* Primary CTA button */}\n          <button\n            onClick={() => handleScrollTo(\"contact\")}\n            className=\"hidden sm:flex items-center gap-1.5 px-4 py-2 rounded-full bg-white text-black hover:bg-neutral-200 font-bold text-xs tracking-wide transition-colors cursor-pointer shadow-lg shadow-black/10\"\n          >\n            <Sparkles className=\"w-3.5 h-3.5 text-orange-500\" />\n            Hire Dhanush\n          </button>\n\n          {/* Mobile hamburger menu */}\n          <button\n            onClick={() => setMobileMenuOpen(!mobileMenuOpen)}\n            className={`md:hidden p-2 rounded-xl border backdrop-blur-sm transition-colors ${\n              isDarkMode\n                ? \"bg-neutral-950/40 border-white/[0.05] text-white\"\n                : \"bg-white/80 border-black/[0.06] text-neutral-900\"\n            }`}\n          >\n            {mobileMenuOpen ? <X className=\"w-4 h-4\" /> : <Menu className=\"w-4 h-4\" />}\n          </button>\n        </div>\n      </div>\n\n      {/* Mobile Drawer panel */}\n      {mobileMenuOpen && (\n        <motion.div\n          initial={{ opacity: 0, y: -10 }}\n          animate={{ opacity: 1, y: 0 }}\n          exit={{ opacity: 0, y: -10 }}\n          className={`absolute top-20 left-4 right-4 z-50 p-5 rounded-2xl border backdrop-blur-lg shadow-2xl pointer-events-auto ${\n            isDarkMode\n              ? \"bg-neutral-950/95 border-white/[0.08]\"\n              : \"bg-white/95 border-black/[0.08]\"\n          }`}\n        >\n          <div className=\"flex flex-col gap-3\">\n            {menuItems.map((item) => {\n              const isActive = activeSection === item.id;\n              return (\n                <button\n                  key={item.id}\n                  onClick={() => handleScrollTo(item.id)}\n                  className={`px-4 py-3 rounded-xl text-left text-sm font-bold transition-all ${\n                    isActive\n                      ? \"bg-orange-500/10 text-orange-500 border border-orange-500/20\"\n                      : isDarkMode\n                      ? \"text-zinc-300 hover:bg-white/5\"\n                      : \"text-neutral-700 hover:bg-black/5\"\n                  }`}\n                >\n                  {item.label}\n                </button>\n              );\n            })}\n            <button\n              onClick={() => handleScrollTo(\"contact\")}\n              className=\"mt-2 w-full flex items-center justify-center gap-2 py-3 rounded-xl bg-orange-500 text-white font-bold text-xs tracking-wider\"\n            >\n              <Sparkles className=\"w-4 h-4\" />\n              HIRE DHANUSH\n            </button>\n          </div>\n        </motion.div>\n      )}\n    </header>\n  );\n}\n"
    }
