    replacement_chunks {
      replacement_content: "import { motion, useMotionValue, useSpring } from \"motion/react\";\nimport { useEffect } from \"react\";\n\ninterface SlatBackgroundProps {\n  isDarkMode: boolean;\n}\n\nexport default function SlatBackground({ isDarkMode }: SlatBackgroundProps) {\n  // Mouse tracking for parallax\n  const mouseX = useMotionValue(0.5);\n  const mouseY = useMotionValue(0.5);\n\n  const springX = useSpring(mouseX, { stiffness: 50, damping: 20 });\n  const springY = useSpring(mouseY, { stiffness: 50, damping: 20 });\n\n  useEffect(() => {\n    const handleMouseMove = (e: MouseEvent) => {\n      // Normalize values between -0.5 and 0.5\n      mouseX.set((e.clientX / window.innerWidth) - 0.5);\n      mouseY.set((e.clientY / window.innerHeight) - 0.5);\n    };\n\n    window.addEventListener(\"mousemove\", handleMouseMove);\n    return () => window.removeEventListener(\"mousemove\", handleMouseMove);\n  }, [mouseX, mouseY]);\n\n  // Wave profile heights for the 10 vertical columns\n  const waveOffsets = [45, 55, 68, 80, 85, 75, 62, 50, 42, 35];\n\n  return (\n    <div className=\"absolute inset-0 overflow-hidden pointer-events-none z-0\">\n      {/* 10 vertical slats grid overlays */}\n      <div className=\"absolute inset-0 grid grid-cols-5 md:grid-cols-10 h-full w-full\">\n        {Array.from({ length: 10 }).map((_, i) => {\n          const heightOffset = waveOffsets[i] || 50;\n          return (\n            <div\n              key={i}\n              className={`h-full w-full relative transition-colors duration-700 ${\n                i >= 5 ? \"hidden md:block\" : \"\"\n              } ${\n                isDarkMode \n                  ? \"border-r border-white/[0.03]\" \n                  : \"border-r border-black/[0.02]\"\n              }`}\n            >\n              {/* Sliced Wave Glow Element inside the slat */}\n              <motion.div\n                className={`absolute left-1/2 -translate-x-1/2 w-[240px] h-[240px] rounded-full blur-[80px] pointer-events-none opacity-40 mix-blend-screen transition-all duration-700`}\n                style={{\n                  top: `${heightOffset}%`,\n                  x: springX.get() * (i * -12 + 60),\n                  y: springY.get() * (i * 12 - 60),\n                  background: isDarkMode\n                    ? `radial-gradient(circle, ${\n                        i % 3 === 0 \n                          ? \"rgba(255, 92, 0, 0.45) 0%\" \n                          : i % 3 === 1 \n                          ? \"rgba(234, 179, 8, 0.35) 0%\" \n                          : \"rgba(249, 115, 22, 0.4) 0%\"\n                      }, transparent 70%)`\n                    : `radial-gradient(circle, ${\n                        i % 3 === 0 \n                          ? \"rgba(255, 140, 0, 0.25) 0%\" \n                          : i % 3 === 1 \n                          ? \"rgba(251, 191, 36, 0.2) 0%\" \n                          : \"rgba(251, 146, 60, 0.22) 0%\"\n                      }, transparent 70%)`,\n                }}\n                animate={{\n                  scale: [1, 1.15, 0.95, 1],\n                  opacity: [0.35, 0.48, 0.38, 0.35],\n                }}\n                transition={{\n                  duration: 6 + (i % 3) * 2.5,\n                  repeat: Infinity,\n                  ease: \"easeInOut\",\n                }}\n              />\n\n              {/* Slat hover trigger lines */}\n              <motion.div \n                className=\"absolute top-0 right-0 h-full w-[2px] opacity-0 hover:opacity-100 transition-opacity bg-gradient-to-b from-transparent via-orange-500/35 to-transparent\"\n                style={{\n                  height: \'100%\'\n                }}\n              />\n            </div>\n          );\n        })}\n      </div>\n\n      {/* Extreme ambient back glow */}\n      <div \n        className={`absolute top-1/4 left-1/4 w-[50vw] h-[50vw] rounded-full filter blur-[140px] mix-blend-screen pointer-events-none transition-all duration-1000 ${\n          isDarkMode \n            ? \"bg-gradient-to-tr from-orange-950/20 to-zinc-950/0 opacity-60\" \n            : \"bg-gradient-to-tr from-orange-100/10 to-transparent opacity-40\"\n        }`} \n      />\n\n      {/* Grid Pattern mask overlay */}\n      <div \n        className={`absolute inset-0 opacity-[0.035] pointer-events-none transition-opacity duration-700 ${\n          isDarkMode ? \"invert-0\" : \"invert\"\n        }`}\n        style={{\n          backgroundImage: `radial-gradient(rgba(255, 255, 255, 0.15) 1px, transparent 1px)`,\n          backgroundSize: \'24px 24px\'\n        }}\n      />\n    </div>\n  );\n}\n"
    }
