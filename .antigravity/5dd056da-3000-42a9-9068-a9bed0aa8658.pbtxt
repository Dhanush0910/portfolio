    replacement_chunks {
      target_content: "export default function HUDNodes({ isDarkMode, onNodeClick }: HUDNodesProps) {\n  const getIcon = (id: string) => {\n    switch (id) {\n      case \"core-stack\":\n        return <Award className=\"w-3.5 h-3.5 text-orange-400\" />;\n      case \"uptime\":\n        return <Zap className=\"w-3.5 h-3.5 text-amber-400 animate-pulse\" />;\n      case \"security\":\n        return <ShieldCheck className=\"w-3.5 h-3.5 text-orange-500\" />;\n      default:\n        return <Cpu className=\"w-3.5 h-3.5 text-amber-500\" />;\n    }\n  };\n\n  return (\n    <div className=\"absolute inset-0 z-10 pointer-events-none\">\n      {defaultNodes.map((node, index) => {\n        // Simple float offset generator\n        const floatY = [0, -10, 10, 0];\n        const floatX = [0, 8, -8, 0];\n        const duration = 6 + index * 2;\n\n        return (\n          <motion.div\n            key={node.id}\n            className=\"absolute hidden md:block pointer-events-auto\"\n            style={{\n              left: `${node.x}%`,\n              top: `${node.y}%`,\n            }}\n            animate={{\n              y: floatY,\n              x: floatX,\n            }}\n            transition={{\n              duration: duration,\n              repeat: Infinity,\n              ease: \"easeInOut\",\n            }}\n          >\n            {/* Hover capsule */}\n            <motion.div\n              className={`flex items-center gap-3 px-3 py-2 rounded-xl backdrop-blur-md border shadow-2xl cursor-pointer select-none transition-all duration-300 ${\n                isDarkMode\n                  ? \"bg-neutral-950/70 border-white/[0.08] hover:border-orange-500/40 text-white shadow-black/80\"\n                  : \"bg-white/80 border-black/[0.06] hover:border-orange-500/30 text-neutral-900 shadow-neutral-200\"\n              }`}\n              whileHover={{\n                scale: 1.05,\n                y: -4,\n              }}\n              onClick={() => onNodeClick?.(node)}\n            >\n              {/* LED Ping Node */}\n              <div className=\"relative flex h-2 w-2\">\n                <span\n                  className={`animate-ping absolute inline-flex h-full w-full rounded-full opacity-75 ${\n                    node.status === \"encrypted\"\n                      ? \"bg-orange-500\"\n                      : node.status === \"active\"\n                      ? \"bg-amber-500\"\n                      : \"bg-emerald-500\"\n                  }`}\n                />\n                <span\n                  className={`relative inline-flex rounded-full h-2 w-2 ${\n                    node.status === \"encrypted\"\n                      ? \"bg-orange-500\"\n                      : node.status === \"active\"\n                      ? \"bg-amber-500\"\n                      : \"bg-emerald-500\"\n                  }`}\n                />\n              </div>\n\n              {/* Node meta */}\n              <div className=\"flex flex-col\">\n                <span\n                  className={`text-[9px] font-mono tracking-widest font-semibold uppercase ${\n                    isDarkMode ? \"text-zinc-500\" : \"text-neutral-400\"\n                  }`}\n                >\n                  {node.label}\n                </span>\n                <span className=\"text-xs font-semibold font-display tracking-tight flex items-center gap-1\">\n                  {getIcon(node.id)}\n                  {node.value}\n                </span>\n              </div>\n            </motion.div>\n\n            {/* Glowing vertical connector line dropping to target */}\n            <div\n              className={`w-[1px] h-10 absolute left-6 -z-10 bg-gradient-to-b ${\n                isDarkMode\n                  ? \"from-orange-500/20 via-orange-500/5 to-transparent\"\n                  : \"from-orange-500/10 via-orange-500/0 to-transparent\"\n              }`}\n            />\n          </motion.div>\n        );\n      })}\n    </div>\n  );\n}"
      replacement_content: "export default function HUDNodes({ isDarkMode, onNodeClick }: HUDNodesProps) {\n  const getIcon = (id: string) => {\n    switch (id) {\n      case \"core-stack\":\n        return <Award className=\"w-3.5 h-3.5 text-blue-400\" />;\n      case \"uptime\":\n        return <Zap className=\"w-3.5 h-3.5 text-blue-400 animate-pulse\" />;\n      case \"security\":\n        return <ShieldCheck className=\"w-3.5 h-3.5 text-indigo-400\" />;\n      default:\n        return <Cpu className=\"w-3.5 h-3.5 text-blue-500\" />;\n    }\n  };\n\n  return (\n    <div className=\"absolute inset-0 z-10 pointer-events-none\">\n      {defaultNodes.map((node, index) => {\n        // Simple float offset generator\n        const floatY = [0, -10, 10, 0];\n        const floatX = [0, 8, -8, 0];\n        const duration = 6 + index * 2;\n\n        return (\n          <motion.div\n            key={node.id}\n            className=\"absolute hidden md:block pointer-events-auto\"\n            style={{\n              left: `${node.x}%`,\n              top: `${node.y}%`,\n            }}\n            animate={{\n              y: floatY,\n              x: floatX,\n            }}\n            transition={{\n              duration: duration,\n              repeat: Infinity,\n              ease: \"easeInOut\",\n            }}\n          >\n            {/* Hover capsule */}\n            <motion.div\n              className={`flex items-center gap-3 px-3 py-2 rounded-xl backdrop-blur-md border shadow-2xl cursor-pointer select-none transition-all duration-300 ${\n                isDarkMode\n                  ? \"bg-neutral-950/70 border-white/[0.08] hover:border-blue-500/40 text-white shadow-black/80\"\n                  : \"bg-white/80 border-black/[0.06] hover:border-blue-500/30 text-neutral-900 shadow-neutral-200\"\n              }`}\n              whileHover={{\n                scale: 1.05,\n                y: -4,\n              }}\n              onClick={() => onNodeClick?.(node)}\n            >\n              {/* LED Ping Node */}\n              <div className=\"relative flex h-2 w-2\">\n                <span\n                  className={`animate-ping absolute inline-flex h-full w-full rounded-full opacity-75 ${\n                    node.status === \"encrypted\"\n                      ? \"bg-indigo-500\"\n                      : node.status === \"active\"\n                      ? \"bg-blue-500\"\n                      : \"bg-emerald-500\"\n                  }`}\n                />\n                <span\n                  className={`relative inline-flex rounded-full h-2 w-2 ${\n                    node.status === \"encrypted\"\n                      ? \"bg-indigo-500\"\n                      : node.status === \"active\"\n                      ? \"bg-blue-500\"\n                      : \"bg-emerald-500\"\n                  }`}\n                />\n              </div>\n\n              {/* Node meta */}\n              <div className=\"flex flex-col\">\n                <span\n                  className={`text-[9px] font-mono tracking-widest font-semibold uppercase ${\n                    isDarkMode ? \"text-zinc-500\" : \"text-neutral-400\"\n                  }`}\n                >\n                  {node.label}\n                </span>\n                <span className=\"text-xs font-semibold font-display tracking-tight flex items-center gap-1\">\n                  {getIcon(node.id)}\n                  {node.value}\n                </span>\n              </div>\n            </motion.div>\n\n            {/* Glowing vertical connector line dropping to target */}\n            <div\n              className={`w-[1px] h-10 absolute left-6 -z-10 bg-gradient-to-b ${\n                isDarkMode\n                  ? \"from-blue-500/20 via-blue-500/5 to-transparent\"\n                  : \"from-blue-500/10 via-blue-500/0 to-transparent\"\n              }`}\n            />\n          </motion.div>\n        );\n      })}\n    </div>\n  );\n}"
    }
